{{!
    @template tool_consentwithdraw/consent_modal

    Body content for the AI-policy consent-status modal shown to the current user.

    Context variables required for this template:
    * accepted           - true if the user has accepted the AI policy (boolean)
    * recordid           - ai_policy_register record ID (int; 0 when not accepted)
    * policy_accepted    - translated "Policy accepted" string (string)
    * policy_not_accepted - translated "Policy not accepted" string (string)
    * btn_withdraw       - translated label for the withdraw button (string)
}}
<div class="tool-consentwithdraw-modal-body">
    {{#accepted}}
    <p>{{policy_accepted}}</p>
    <button class="btn btn-danger float-end"
            id="consent-withdraw-btn"
            data-recordid="{{recordid}}"
            aria-label="{{btn_withdraw}}">
        {{btn_withdraw}}
    </button>
    {{/accepted}}
    {{^accepted}}
    <p>{{policy_not_accepted}}</p>
    {{/accepted}}
</div>
