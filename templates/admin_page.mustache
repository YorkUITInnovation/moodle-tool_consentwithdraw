{{!
    @template tool_consentwithdraw/admin_page

    Admin tool page for managing AI policy consent withdrawal.

    Context variables required for this template:
    * sesskey          - Moodle session key (string)
    * search_label     - Translated label for the user-search field (string)
    * search_help      - Translated help text for the user-search field (string)
    * no_user_selected - Message shown when no user has been selected yet (string)
}}
<div id="tool-consentwithdraw-admin" class="container-fluid py-3">
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="form-group">
                <label for="tool-consentwithdraw-usersearch" class="form-label fw-bold">
                    {{search_label}}
                </label>
                <select id="tool-consentwithdraw-usersearch"
                        name="usersearch"
                        class="form-control">
                </select>
                <small class="form-text text-muted">{{search_help}}</small>
            </div>
        </div>
    </div>

    <div id="tool-consentwithdraw-status"
         class="row"
         aria-live="polite"
         aria-relevant="all">
        <div class="col">
            <p class="text-muted">{{no_user_selected}}</p>
        </div>
    </div>
</div>
